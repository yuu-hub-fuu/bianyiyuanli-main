fn quad(a: f64, b: f64, c: f64) -> f64 {
    return a * b + c;
}

fn main() -> i32 {
    let x: f64 = 1.5 + 2.25;
    print(x);
    let y: f64 = quad(2.0, 3.5, 0.5);
    print(y);
    if x > 3.0 {
        print(1);
    } else {
        print(0);
    }
    if y == 7.5 {
        return 42;
    }
    return 7;
}
